# ==============================================================================
# ResumeHub Backend Environment Configuration Template
# Rename this file to .env and fill in your keys.
# ==============================================================================

# API Key for Groq
GROQ_API_KEY=your_groq_api_key_here

# SQLite Database File Path (defaults to resumehub.db)
DB_PATH=resumehub.db

# Admin Authorization Secret (for admin API routes/dashboard)
ADMIN_SECRET=your_admin_secret_here

# Toggle Free Mode (set to false to enable authentication/monetization features)
FREE_MODE=true

# List of Gemini developer API keys (comma-separated if using multiple)
GEMINI_API_KEYS=key1,key2,key3

# Legacy/Single Gemini API Key fallback
GEMINI_API_KEY=your_gemini_api_key_here
